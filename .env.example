# ─── Appwrite ────────────────────────────────────────────────────────────────
VITE_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
VITE_APPWRITE_PROJECT_ID=YOUR_PROJECT_ID
VITE_APPWRITE_DATABASE_ID=socialpulse_db

# ─── Collection IDs (auto-created by: npm run setup) ─────────────────────────
VITE_APPWRITE_USERS_COLLECTION=users
VITE_APPWRITE_VIDEOS_COLLECTION=videos
VITE_APPWRITE_COMMENTS_COLLECTION=comments
VITE_APPWRITE_LIKES_COLLECTION=likes
VITE_APPWRITE_FOLLOWS_COLLECTION=follows
VITE_APPWRITE_SAVES_COLLECTION=saves
VITE_APPWRITE_NOTIFICATIONS_COLLECTION=notifications
VITE_APPWRITE_CONVERSATIONS_COLLECTION=conversations
VITE_APPWRITE_MESSAGES_COLLECTION=messages
VITE_APPWRITE_VIDEO_VIEWS_COLLECTION=video_views
VITE_APPWRITE_HASHTAGS_COLLECTION=hashtags
VITE_APPWRITE_REPORTS_COLLECTION=reports
VITE_APPWRITE_BLOCKED_USERS_COLLECTION=blocked_users
VITE_APPWRITE_ADMIN_LOGS_COLLECTION=admin_logs

# ─── Storage Buckets (auto-created by: npm run setup) ────────────────────────
VITE_BUCKET_VIDEOS=videos
VITE_BUCKET_THUMBNAILS=thumbnails
VITE_BUCKET_AVATARS=avatars
VITE_BUCKET_COVERS=covers
VITE_BUCKET_MESSAGES=messages_media



# ============================================
# CLOUDINARY CONFIGURATION
# ============================================
# Fill these in from your Cloudinary console (Settings -> Upload for the
# preset, dashboard home for the cloud name). The preset must be Unsigned.
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=
VITE_APPWRITE_CLOUDINARY_FUNCTION_ID=cloudinary-cleanup